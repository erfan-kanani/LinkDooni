# Never commit a real Telegram bot token.
TELEGRAM_BOT_TOKEN=123456789:replace-me

# SQLite is the MVP default. PostgreSQL can be added by swapping this URL
# once a PostgreSQL async driver is configured.
DATABASE_URL=sqlite+aiosqlite:///./linkdooni.db

# Optional Docker PostgreSQL development database:
# DATABASE_URL=postgresql+asyncpg://linkdooni:linkdooni@localhost:5432/linkdooni

LOG_LEVEL=INFO
CONFIG_DIR=app/config
LINKDOONI_AUTO_CREATE_DB=true
